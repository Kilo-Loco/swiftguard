{
  "name": "swiftguard",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "deploy": "vercel --prod",
    "test": "vitest run",
    "test:watch": "vitest",
    "validate:clone": "bash scripts/clone-repos.sh",
    "validate:run": "npx tsx scripts/validate.ts",
    "validate": "npm run validate:clone && npm run validate:run",
    "validate:prs": "npx tsx scripts/pr-validate.ts",
    "test:pipeline": "npx tsx scripts/test-pipeline.ts --full",
    "test:repos": "npx tsx scripts/test-pipeline.ts --repos",
    "test:prs": "npx tsx scripts/test-pipeline.ts --prs",
    "test:baseline": "npx tsx scripts/test-pipeline.ts --baseline",
    "test:compare": "npx tsx scripts/test-pipeline.ts --compare"
  },
  "dependencies": {
    "next": "16.2.1",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "tree-sitter": "^0.22.4",
    "tree-sitter-swift": "^0.7.1"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.2",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.1",
    "tailwindcss": "^4.2.2",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "vitest": "^4.1.2"
  }
}
